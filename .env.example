# Frontend
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_API_URL=http://localhost:4100

# Backend
PORT=4100
CORS_ORIGIN=true
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_STORAGE_BUCKET=project-uploads
MAX_UPLOAD_MB=100
ENABLE_LOCAL_AI=true
LOCAL_AI_MODEL=Xenova/all-MiniLM-L6-v2

# AI Report Assistant
# Option A: use the free messages-based demo API
AI_CHAT_API_URL=https://gpt-api-bay.vercel.app/chat
AI_CHAT_API_FORMAT=messages

# Option B: use an OpenAI-compatible chat API
# AI_CHAT_API_URL=https://api.openai.com/v1/chat/completions
# AI_CHAT_API_FORMAT=openai
AI_CHAT_API_KEY=
AI_CHAT_MODEL=gpt-4o-mini

# Option C: use a local Hugging Face text generation model
ENABLE_REPORT_ASSISTANT_AI=true
REPORT_ASSISTANT_MODEL=Xenova/flan-t5-small
REPORT_ASSISTANT_TASK=text2text-generation
